#!/usr/bin/env bash
# tmux-projects: create a tmux session for each project you've WORKED ON within
# the last N days. Projects are auto-discovered under ROOT. Two folder layouts
# are supported, and the SAME script figures out which one a machine uses:
#
#   nested:  ROOT/<category>/<project>   (e.g. a work Mac: ~/Development/oracle/oci-api)
#   flat:    ROOT/<project>              (e.g. a personal Mac: ~/Development/oci-api)
#
# By default LAYOUT=auto decides per top-level folder: a git repo (or a folder
# with no subfolders) is a PROJECT; a folder that contains subfolders is a
# CATEGORY whose subfolders are projects. That means auto also handles a MIXED
# root that has some loose repos alongside some category folders. Force a single
# interpretation with LAYOUT / the DEV_LAYOUT env var (see config below). Add a
# new project or category and it's picked up automatically, no edit needed.
#
# "Worked on" means a file in the working tree was modified within the window.
# The .git folder and common build/dependency folders are ignored, so merely
# opening, cd-ing into, listing, or running git status in a project does NOT
# count. Only actually writing to a file does.
#
# Known caveat: a heavy `git pull` / `checkout` / `clone` rewrites file
# timestamps to "now", which can make a repo look freshly edited even if you
# only pulled. It ages out after the window passes.
#
# Re-running this is safe: sessions that already exist are left untouched.

set -u

# ---- config ----------------------------------------------------------------
# Where your category folders live. The SAME script works on multiple Macs:
# it uses $DEV_ROOT if that env var is set, otherwise the first of these paths
# that exists (so a work Mac with ~/Development and a personal Mac with
# ~/Developer both just work). Edit the list to match your machines.
DEV_ROOT_CANDIDATES=( "$HOME/Developer" "$HOME/Development" "$HOME/dev" "$HOME/code" )
DAYS=14                    # "past 2 weeks"
START_CLAUDE=false         # set true to auto-run `claude` in the left pane of each session

# Folder layout under ROOT. One of: auto | flat | nested.
#   auto   - decide per top-level folder (git repo/leaf = project, else category).
#            Handles flat, nested, AND mixed roots. Best default for multiple Macs.
#   flat   - every top-level folder is a project     (ROOT/<project>).
#   nested - every top-level folder is a category     (ROOT/<category>/<project>).
# Override without editing this file via the DEV_LAYOUT env var (like DEV_ROOT).
LAYOUT="${DEV_LAYOUT:-auto}"

# Top-level folders to skip entirely (dotfolders like .vscode are always skipped).
# In nested mode these are categories; in flat/auto mode they can also be projects.
# e.g. EXCLUDE_CATEGORIES=( "archive" ).
EXCLUDE_CATEGORIES=( )
# ----------------------------------------------------------------------------

# Resolve the dev root: explicit $DEV_ROOT wins, else first candidate that exists.
ROOT="${DEV_ROOT:-}"
if [ -z "$ROOT" ]; then
  for cand in "${DEV_ROOT_CANDIDATES[@]}"; do
    [ -d "$cand" ] && { ROOT="$cand"; break; }
  done
fi
if [ -z "$ROOT" ] || [ ! -d "$ROOT" ]; then
  echo "tmux-projects: no dev root found." >&2
  echo "  Set DEV_ROOT, or create one of: ${DEV_ROOT_CANDIDATES[*]}" >&2
  exit 1
fi

case "$LAYOUT" in
  auto|flat|nested) ;;
  *) echo "tmux-projects: invalid LAYOUT '$LAYOUT' (use auto, flat, or nested)." >&2
     exit 1 ;;
esac

# tmux session names can't contain '.' or ':'; turn those (and spaces) into '-'.
sanitize() { printf '%s' "$1" | tr ' .:' '---'; }

# True if a category name is in EXCLUDE_CATEGORIES (safe even on bash 3.2 / empty array).
is_excluded() {
  local name="$1" ex
  for ex in "${EXCLUDE_CATEGORIES[@]+"${EXCLUDE_CATEGORIES[@]}"}"; do
    [ "$name" = "$ex" ] && return 0
  done
  return 1
}

# Active if any working-tree file was modified within DAYS days (noise pruned).
is_active() {
  local dir="$1"
  find "$dir" \
    \( -path '*/.git' -o -path '*/node_modules' -o -path '*/.terraform' \
       -o -path '*/target' -o -path '*/build' -o -path '*/dist' \
       -o -path '*/.venv' -o -path '*/vendor' \) -prune \
    -o -type f -mtime -"$DAYS" -print 2>/dev/null \
    | head -1 | grep -q .
}

# NOTE (optional, not enabled): for GIT repos you can detect activity by the
# last COMMIT date instead of file mtimes. That is immune to `git pull` /
# `checkout` rewriting timestamps. To enable, define the helper below and use
# `if git_recent "$dir" || is_active "$dir"; then` in the scan loop.
#
#   git_recent() {   # returns 0 (true) if HEAD was committed within DAYS days
#     local dir="$1" last now
#     [ -d "$dir/.git" ] || return 1
#     last=$(git -C "$dir" log -1 --format=%ct 2>/dev/null) || return 1
#     now=$(date +%s)
#     [ -n "$last" ] && [ $(( (now - last) / 86400 )) -lt "$DAYS" ]
#   }

# True if DIR contains at least one non-dotfolder subdirectory. Used by LAYOUT=auto
# to tell a category (holds project subfolders) from a flat/leaf project.
has_subdirs() {
  local d="$1" sub
  for sub in "$d"/*/; do
    [ -d "$sub" ] || continue
    case "$(basename "$sub")" in .*) continue;; esac
    return 0
  done
  return 1
}

# Open a session for a single project DIR if it's been worked on recently.
# Bumps the global $count. Dotfolders are skipped.
consider_project() {
  local dir="${1%/}" projname
  projname="$(basename "$dir")"
  case "$projname" in .*) return;; esac
  if is_active "$dir"; then
    create_session "$dir" "$(sanitize "$projname")"
    count=$((count + 1))
  fi
}

# Create a detached session: one window, two panes (left = work/claude, right = shell).
create_session() {
  local dir="$1" name="$2"
  if tmux has-session -t "=$name" 2>/dev/null; then
    echo "  - $name (already running, left as-is)"
    return
  fi
  tmux new-session -d -s "$name" -n work -c "$dir"
  tmux split-window -h -l 40% -t "$name:work" -c "$dir"   # right pane = 40% wide
  tmux select-pane -t "$name:work.1"                      # focus the left pane
  if [ "$START_CLAUDE" = true ]; then
    tmux send-keys -t "$name:work.1" 'claude' C-m
  fi
  echo "  - $name  ->  $dir"
}

echo "Scanning $ROOT for projects worked on in the last $DAYS days (layout: $LAYOUT)..."
count=0
# Walk each top-level folder under ROOT. Depending on LAYOUT it's either a
# project itself (flat) or a category whose subfolders are projects (nested).
# (If two projects share a name, the first one wins and the second is reported
# as "already running" -- rename one to avoid that.)
for entry in "$ROOT"/*/; do
  [ -d "$entry" ] || continue                 # ROOT has no subfolders
  entry="${entry%/}"
  name="$(basename "$entry")"
  case "$name" in .*) continue;; esac          # skip dotfolders (.vscode, .git, ...)
  is_excluded "$name" && continue

  # Decide whether this top-level folder is a category (descend one level) or a
  # project (use it directly).
  case "$LAYOUT" in
    flat)   is_category=false ;;
    nested) is_category=true ;;
    auto)
      if [ -d "$entry/.git" ]; then
        is_category=false                     # a repo is a project, not a category
      elif has_subdirs "$entry"; then
        is_category=true                      # holds subfolders -> category
      else
        is_category=false                     # leaf folder -> treat as a project
      fi ;;
  esac

  if [ "$is_category" = true ]; then
    for dir in "$entry"/*/; do
      [ -d "$dir" ] || continue               # category has no projects
      consider_project "$dir"
    done
  else
    consider_project "$entry"
  fi
done

echo ""
if [ "$count" -eq 0 ]; then
  echo "No active projects found in the last $DAYS days."
  exit 0
fi

echo "$count active session(s) ready:"
tmux ls

# If we're not already inside tmux, drop straight into the first session.
if [ -z "${TMUX:-}" ]; then
  first=$(tmux ls -F '#{session_name}' | head -1)
  echo ""
  echo "Attaching to '$first'  (prefix d = detach, prefix s = switch projects)"
  exec tmux attach -t "$first"
fi
